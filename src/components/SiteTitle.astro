---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<div class="site-title sl-flex">
	<a href="https://dassi.ai" class="logo-link">
		<span class="logo-icon">
			<span class="bracket">[</span>
			<span class="logo-d">d</span>
			<span class="bracket">]</span>
		</span>
		<span class="logo-text" translate="no">dassi</span>
	</a>
	<span class="logo-divider">/</span>
	<a href={siteTitleHref} class="docs-link">
		<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
		<span class="logo-label">docs</span>
	</a>
</div>

<style>
	@layer starlight.core {
		.site-title {
			align-items: center;
			gap: 8px;
			font-size: 18px;
			font-weight: 700;
			white-space: nowrap;
			min-width: 0;
			font-family: 'JetBrains Mono', monospace;
		}
		.logo-link,
		.docs-link {
			display: flex;
			align-items: center;
			text-decoration: none;
			gap: 8px;
		}
		.logo-icon {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 32px;
			height: 32px;
			background: #FF5C00;
			border-radius: 8px;
			line-height: 1;
			gap: 0;
		}
		.bracket {
			color: rgba(255, 255, 255, 0.5);
			font-size: 18px;
			font-weight: 400;
			font-family: 'JetBrains Mono', monospace;
		}
		.logo-d {
			color: #ffffff;
			font-size: 20px;
			font-weight: 700;
			font-family: 'JetBrains Mono', monospace;
		}
		.logo-text {
			color: #000000;
		}
		.logo-divider {
			color: #dddddd;
			font-weight: 400;
		}
		.docs-link {
			gap: 6px;
			color: #999999;
		}
		.logo-label {
			color: #999999;
			font-weight: 400;
		}
	}
</style>
